# Copy to .env.local

# Public site origin (no trailing slash).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Backend download API (the video-downloader-api service).
NEXT_PUBLIC_API_URL=http://localhost:8080

# Site brand
NEXT_PUBLIC_SITE_NAME=GrabClip

# --- Adsterra ads (optional; slots show placeholders until set) --------------
# Per-size banner zone keys from your Adsterra dashboard (Display Banner units).
NEXT_PUBLIC_ADSTERRA_KEY_728X90=
NEXT_PUBLIC_ADSTERRA_KEY_300X250=
NEXT_PUBLIC_ADSTERRA_KEY_160X600=
# Social Bar / Popunder: the full invoke.js src Adsterra gives you, e.g.
# //pl000000.highperformanceformat.com/xxxxxxxx/invoke.js
NEXT_PUBLIC_ADSTERRA_SOCIALBAR_SRC=
